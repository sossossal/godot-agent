      "starter_feature_name": "visual_novel_save_and_load",
      "dependencies": ["variable_flags"]
    },
    {
      "system_id": "localization_surface",
      "display_name": "Localization Surface",
      "category": "ui",
      "summary": "Text surface and lookup path that keeps story UI localization-ready.",
