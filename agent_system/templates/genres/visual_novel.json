    {
      "system_id": "scene_transition",
      "display_name": "Scene Transition",
      "category": "flow",
      "summary": "Transition flow between story scenes, menus, and route milestones.",
      "recommended_skills": ["define_game_flow", "apply_tween_animation"],
      "suggested_data_tables": ["quest", "localization"],
