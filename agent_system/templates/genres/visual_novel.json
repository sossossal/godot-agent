      "starter_feature_name": "visual_novel_variable_flags",
      "dependencies": ["branching_choices"]
    },
    {
      "system_id": "save_and_load",
      "display_name": "Save And Load",
      "category": "state",
      "summary": "Manual and quick save flow for story progress and route state.",
      "recommended_skills": ["plan_game_feature", "manage_blueprint_snapshots"],
      "suggested_data_tables": [],
