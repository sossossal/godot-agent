      "dependencies": []
    },
    {
      "system_id": "branching_choices",
      "display_name": "Branching Choices",
      "category": "narrative",
      "summary": "Choice selection and route branching with immediate UI feedback.",
      "recommended_skills": ["generate_dialogue_system", "manage_signal_bus"],
