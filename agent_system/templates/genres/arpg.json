      "starter_feature_name": "arpg_quest_and_interaction",
      "dependencies": ["player_controller"]
    },
    {
      "system_id": "loot_and_inventory",
      "display_name": "Loot And Inventory",
      "category": "economy",
      "summary": "Drop pickup, inventory state, and item reward presentation.",
      "recommended_skills": ["manage_game_data_tables", "plan_game_feature"],
