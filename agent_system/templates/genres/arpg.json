      "starter_feature_name": "arpg_health_and_resources",
      "dependencies": ["combat_abilities"]
    },
    {
      "system_id": "quest_and_interaction",
      "display_name": "Quest And Interaction",
      "category": "progression",
      "summary": "Quest giver, world interaction, and objective completion events.",
      "recommended_skills": ["manage_game_data_tables", "manage_level_workflow"],
      "suggested_data_tables": ["quest", "localization"],
